#!/bin/bash

# Pre-commit hook to block direct commits to main
branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "main" ]; then
  echo ""
  echo "❌ Opa! Commits diretos na branch 'main' não são permitidos!"
  echo "💡 Por favor, crie uma nova branch para suas alterações e abra um Pull Request."
  echo "Exemplo: git checkout -b feat/nova-funcionalidade"
  echo ""
  exit 1
fi

exit 0
